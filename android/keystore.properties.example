# Copy to `android/keystore.properties` (do not commit the real file).
#
# Windows example:
# storeFile=app/app002-release.keystore
#
# Passwords and alias must match what you used in `keytool -genkeypair`.
storeFile=app/app002-release.keystore
storePassword=CHANGE_ME
keyAlias=app002
keyPassword=CHANGE_ME

